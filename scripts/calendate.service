[Unit]
Description=CalenDate
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/calendate
Environment=PYTHONPATH=/home/ubuntu/calendate/src
ExecStart=/home/ubuntu/.local/bin/uv run uvicorn calendate.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
