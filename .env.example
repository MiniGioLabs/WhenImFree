# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-hex-string

# Set to your production domain in prod
BASE_URL=http://localhost:8000

# Set to true in production (requires HTTPS)
HTTPS_ONLY=false

# Optional — SQLite path (defaults to project root calendate.db)
DATABASE_PATH=

# Twilio — get from console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe — get from dashboard.stripe.com
STRIPE_SECRET_KEY=
